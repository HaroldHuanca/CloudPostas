#========================== COPIAR TODO DESDE CEROOOOOOOOOOON =============================
#Copiamos todo del repositorio
cd ~
git clone https://github.com/HaroldHuanca/CloudPostas.git
cd ~/CloudPostas

#Crear el cluster multi-nodo
# 1. Asegurar que el motor de Docker esté encendido en Arch Linux
sudo systemctl start docker

# 2. Crear el clúster limpio con 2 Nodos (esto elimina residuos previos)
minikube delete --all
minikube start --nodes=2

# 3. Activar el registro local dentro de Minikube
minikube addons enable registry

#Instalar promethues y grafana
## 1. Agregar el repositorio oficial de Prometheus a Helm
helm repo add prometheus-community https://prometheus-community.github.io/helm-charts
helm repo update

# 2. Instalar el Stack completo (Prometheus, Grafana, Operators)
helm install prometheus prometheus-community/kube-prometheus-stack

#CONSTRUIMOS Y SUBIMOS LA IMAGEN DEL WORKER
kubectl port-forward --namespace kube-system service/registry 5000:80 &

# Compilar la imagen apuntando al registro interno
docker build -t localhost:5000/msa-worker:1.0 .

# Subirla al almacén interno de minikube
docker push localhost:5000/msa-worker:1.0

# 1. Desplegar los 3 Pods del Worker
kubectl apply -f deployment.yaml

# 2. Desplegar el ServiceMonitor para que Prometheus raspe las métricas
kubectl apply -f servicemonitor.yaml

#Iniciamos grafana
kubectl port-forward svc/prometheus-grafana 3000:80 &

# Configurar o activar tu entorno virtual de Python
python3 -m venv env
source env/bin/activate
pip install -r requirements.txt  # Instalar librerías de GCP Pub/Sub si es necesario

# Arrancar el simulador
python simulador.py

